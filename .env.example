# ============================================================
# AtomQuest Portal — Environment Variables Template
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/atomquest?schema=public"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRY="30d"

# --- API ---
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# --- Email (optional — leave blank to disable email sending) ---
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# --- Optional: Microsoft Entra ID SSO ---
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# --- App ---
NODE_ENV="development"
